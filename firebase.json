{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "cleanUrls": true,
    "trailingSlash": true,
    "rewrites": [
      {
        "source": "/about",
        "destination": "/assets/about.html"
      },
      {
        "source": "/games/*/about",
        "destination": "/assets/details.html"
      }
    ]
  }
}
